# required:
# https://github.com/mholt/caddy-ratelimit
# https://github.com/ueffel/caddy-brotli
# https://github.com/caddy-dns/edgeone

(_tls_intermediate_auto) {
	tls {
		protocols tls1.2 tls1.3

		# for EdgeOne
		propagation_timeout 10m
		propagation_delay 5m
		resolvers ns1.qeodns.com ns2.qeodns.com
	}
}

(_compress) {
	encode gzip br zstd
}

(_access_log) {
	log {
		output file /server/caddy/logs/access {
			roll_disabled
		}
	}
}

(_basic) {
	import _tls_intermediate_auto
	import _compress
	import _access_log
}

(_hsts) {
	header Strict-Transport-Security "max-age=63072000"
}

(_rate_limit_http) {
	rate_limit {
		key {http.request.remote.host}
		max_events 20
		window 1s
	}
}

(_rate_limit_app_openlist) {
	rate_limit {
		key {http.request.remote.host}
		max_events 20
		window 1s
	}
}

(http) {
	import _access_log
	import _rate_limit_http

	redir https:{host}{uri} 301
}

(app_openlist) {
	import _basic
	import _hsts
	import _rate_limit_app_openlist
}

{
	admin unix//server/caddy/admin.sock

	log {
		output file /server/caddy/logs/error {
			roll_disabled
		}
		level INFO
	}

	email ldtstore@126.com

	acme_ca https://acme.zerossl.com/v2/DV90

	acme_dns edgeone {
		secret_id {env.TC_SECRET_ID}
		secret_key {env.TC_SECRET_KEY}
	}

	auto_https disable_redirects

	servers :80 {
		protocols h1

		# deny requests with no/wrong server_name (by default) & sni
		strict_sni_host on
	}

	servers :443 {
		protocols h1 h2

		# deny requests with no/wrong server_name (by default) & sni
		strict_sni_host on
	}
}

nbcshare.lm.pc.wiki:80 {
	import http
}

nbcshare.lm.pc.wiki:443 {
	import app_openlist

	reverse_proxy http://127.0.0.1:38010
	# X-Forwarded-For added by default
}
